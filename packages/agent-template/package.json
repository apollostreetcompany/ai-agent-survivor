{
  "name": "@survivor/agent-template",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "local:smoke": "tsx src/local-runner.ts smoke",
    "test": "bun --filter @survivor/shared build && node --import tsx --test test/*.test.ts",
    "start": "node dist/index.js",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@survivor/shared": "*",
    "discord.js": "^14",
    "better-sqlite3": "^11",
    "ai": "^4",
    "@ai-sdk/anthropic": "^1",
    "@ai-sdk/openai": "^1",
    "imapflow": "^1",
    "nodemailer": "^6"
  },
  "devDependencies": {
    "typescript": "^5.7",
    "tsx": "^4",
    "@types/better-sqlite3": "^7",
    "@types/nodemailer": "^6",
    "@types/node": "^22"
  }
}
