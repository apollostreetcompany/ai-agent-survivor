# Copy this file to packages/infra/.env and fill real values locally.
# Do not commit populated secrets.

# Discord runtime. GUILD_ID is the Discord server ID shared by the GM and agents.
GUILD_ID=
GM_DISCORD_TOKEN=
AGENT_ALPHA_DISCORD_TOKEN=
AGENT_BRAVO_DISCORD_TOKEN=
AGENT_CHARLIE_DISCORD_TOKEN=
AGENT_DELTA_DISCORD_TOKEN=

# Non-secret Discord bot user IDs used by the GM to reject spoofed agent messages.
AGENT_ALPHA_DISCORD_BOT_ID=
AGENT_BRAVO_DISCORD_BOT_ID=
AGENT_CHARLIE_DISCORD_BOT_ID=
AGENT_DELTA_DISCORD_BOT_ID=

# Agent LLM credentials. Each launched agent needs its own key value here.
AGENT_ALPHA_LLM_API_KEY=
AGENT_BRAVO_LLM_API_KEY=
AGENT_CHARLIE_LLM_API_KEY=
AGENT_DELTA_LLM_API_KEY=

# Required public run disclosure. Providers must be openclaw or hermes.
BENCHMARK_WATCHDOG_SUPERVISOR=openclaw
AGENT_ALPHA_CLOUD_SEAT_PROVIDER=openclaw
AGENT_BRAVO_CLOUD_SEAT_PROVIDER=openclaw
AGENT_CHARLIE_CLOUD_SEAT_PROVIDER=hermes
AGENT_DELTA_CLOUD_SEAT_PROVIDER=hermes
AGENT_ALPHA_CLOUD_SEAT_ID=
AGENT_BRAVO_CLOUD_SEAT_ID=
AGENT_CHARLIE_CLOUD_SEAT_ID=
AGENT_DELTA_CLOUD_SEAT_ID=

# Required LLM provider/model disclosure for the public benchmark run.
LLM_PROVIDER=anthropic
AGENT_ALPHA_LLM_MODEL=
AGENT_BRAVO_LLM_MODEL=
AGENT_CHARLIE_LLM_MODEL=
AGENT_DELTA_LLM_MODEL=

# Optional GM narration settings.
NARRATOR_API_KEY=
NARRATOR_MODEL=

# Optional mail settings. The compose stack provides the local mail host.
GM_MAIL_PASS=
AGENT_ALPHA_MAIL_USER=agent-alpha
AGENT_ALPHA_MAIL_PASS=
AGENT_BRAVO_MAIL_USER=agent-bravo
AGENT_BRAVO_MAIL_PASS=
AGENT_CHARLIE_MAIL_USER=agent-charlie
AGENT_CHARLIE_MAIL_PASS=
AGENT_DELTA_MAIL_USER=agent-delta
AGENT_DELTA_MAIL_PASS=

# Local benchmark supervision settings.
BENCHMARK_RUNTIME_DIR=
BENCHMARK_METADATA_PATH=
SURVIVOR_RUN_ID=discord-benchmark
GAME_DATA_PORT=8787
# Discord channel/user target where OpenClaw/Hermes watchdog announcements should post.
OPENCLAW_DISCORD_TARGET=
# Optional command overrides for benchmark:doctor.
BENCHMARK_OPENCLAW_COMMAND=openclaw
BENCHMARK_HERMES_COMMAND=hermes
BENCHMARK_OPENCLAW_SEATS_COMMAND=openclaw agents list --bindings
BENCHMARK_HERMES_SEATS_COMMAND=hermes agents list
BENCHMARK_DOCKER_COMMAND=docker
BENCHMARK_REQUIRE_DOCKER=false
MAX_LOG_AGE_SECONDS=7200
MAX_HEALTH_AGE_SECONDS=7200
