{
  "name": "@survivor/gm-bot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "season": "tsx src/cli/season.ts",
    "season:bootstrap": "tsx src/cli/season.ts bootstrap",
    "season:start": "tsx src/cli/season.ts start",
    "season:setup": "tsx src/cli/season.ts setup",
    "test": "bun --filter @survivor/shared build && node --import tsx --test test/*.test.ts",
    "start": "node dist/index.js",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@survivor/shared": "*",
    "discord.js": "^14",
    "better-sqlite3": "^11",
    "drizzle-orm": "^0.39",
    "node-cron": "^3",
    "ai": "^4",
    "@ai-sdk/anthropic": "^1",
    "nodemailer": "^6"
  },
  "devDependencies": {
    "typescript": "^5.7",
    "tsx": "^4",
    "@types/better-sqlite3": "^7",
    "@types/node-cron": "^3",
    "@types/nodemailer": "^6",
    "@types/node": "^22"
  }
}
